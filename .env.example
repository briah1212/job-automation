# ==============================================================================
# Job Automation Platform - deployment configuration
#
# Copy this file to .env and fill in real values before deploying:
#   cp .env.example .env
#
# ./setup-portable.sh does this for you automatically, generating random
# secrets and leaving only PUBLIC_HOST for you to confirm.
#
# This is the ONLY file docker-compose.yml reads secrets/config from. Nothing
# else on the host needs to exist for a fresh `git clone` +
# `./setup-portable.sh` to produce a fully working deployment.
# ==============================================================================

# ------------------------------------------------------------------------------
# Public address
# ------------------------------------------------------------------------------
# The hostname or IP that a browser will use to reach this server. If you are
# deploying to a remote machine (e.g. a Hermes server reachable at
# hermes.example.com or 10.0.0.5), set this to that address - NOT localhost.
# This gets baked into the frontend at build time (Next.js inlines
# NEXT_PUBLIC_* variables into the client bundle), so it must be correct
# before you build the `web` image, and the image must be rebuilt if it
# changes.
PUBLIC_HOST=localhost

WEB_PORT=3002
API_PORT=8001
MOCK_ATS_PORT=8080
POSTGRES_PORT=5432
REDIS_PORT=6379
MINIO_PORT=9000
MINIO_CONSOLE_PORT=9011

# Derived defaults (override directly if you need something more exotic, e.g.
# a reverse proxy path or HTTPS termination in front of these ports).
NEXT_PUBLIC_API_URL=http://localhost:8001
NEXTAUTH_URL=http://localhost:3002

# ------------------------------------------------------------------------------
# Database
# ------------------------------------------------------------------------------
POSTGRES_DB=job_automation
POSTGRES_USER=postgres
POSTGRES_PASSWORD=change-me

# ------------------------------------------------------------------------------
# Auth / JWT (backend's app.core.config.Settings fields: secret_key,
# algorithm, access_token_expire_minutes - names below must match exactly,
# case-insensitively)
# ------------------------------------------------------------------------------
# Generate with: openssl rand -hex 32
SECRET_KEY=change-me
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=1440

# NextAuth's own session secret (unrelated to SECRET_KEY above).
# Generate with: openssl rand -hex 32
NEXTAUTH_SECRET=change-me

# ------------------------------------------------------------------------------
# ATS credential vault
# ------------------------------------------------------------------------------
# Only `api` and `job-worker` ever hold this key - browser-worker must not
# (see backend/docs/browser-state-machine-design.md section 8).
# Generate with:
#   python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
CREDENTIAL_ENCRYPTION_KEY=change-me

# Shared secret for browser-worker -> api service-to-service calls (the api
# container publishes its port to the host, so these internal routes are not
# protected by Docker network isolation alone).
# Generate with: openssl rand -hex 32
INTERNAL_API_KEY=change-me

# ------------------------------------------------------------------------------
# Object storage (MinIO, S3-compatible - runs in its own container, no
# external account needed)
# ------------------------------------------------------------------------------
MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=change-me
MINIO_BROWSER_BUCKET=browser-artifacts

# ------------------------------------------------------------------------------
# AI provider
# ------------------------------------------------------------------------------
# "mock" needs no external API key or network access at all - useful for
# packaging/testing this deployment before wiring up a real model.
AI_PROVIDER=mock
ANTHROPIC_API_KEY=
OPENAI_API_KEY=
DEEPSEEK_API_KEY=

# ------------------------------------------------------------------------------
# Browser automation
# ------------------------------------------------------------------------------
HEADLESS=true

# Optional: point the browser worker at a persistent, already-authenticated
# remote Chrome instance (e.g. a VPS) over the Chrome DevTools Protocol,
# instead of launching a fresh throwaway local browser per run. Leave unset
# for the default local behavior. Use the plain http:// base (NOT a
# ws://.../devtools/browser/<uuid> URL) - confirmed live that Playwright
# resolves the current websocket endpoint from this on every connection, so
# it keeps working across Chrome restarts (which mint a new uuid) with no
# code or config change. Must only ever be reachable privately - never a
# bare public host:port, since the CDP debug port grants full control of a
# browser logged into real accounts. If Chrome runs on the same host as
# browser-worker's own container (e.g. a systemd-managed Chrome on the VPS
# itself), "localhost" from inside that container is the CONTAINER, not the
# host - use host.docker.internal instead (already wired to the Linux host
# gateway in docker-compose.yml's browser-worker service).
# Example: BROWSER_CDP_URL=http://host.docker.internal:9222
BROWSER_CDP_URL=

# ------------------------------------------------------------------------------
# Infra port binding
# ------------------------------------------------------------------------------
# Host interface that postgres/redis/minio's ports are published on. Defaults
# to loopback-only so a server with a public IP doesn't expose an
# unauthenticated (or default-credentialed) database/cache/object-store to
# the internet. Only widen this (e.g. to 0.0.0.0) if you specifically need
# remote access to these ports directly - prefer an SSH tunnel instead.
INFRA_BIND=127.0.0.1
